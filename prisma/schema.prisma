generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MealPeriod {
  BREAKFAST
  LUNCH
  DINNER
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED
  WAITLISTED
}

enum SectionPreference {
  INDOOR
  OUTDOOR
  NO_PREFERENCE
}

enum NotificationType {
  CONFIRMATION
  REMINDER
  CANCELLATION
  ADMIN_ALERT
}

enum NotificationStatus {
  SENT
  FAILED
}

model Section {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  capacity  Int
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("sections")
}

model OperatingHours {
  id         String     @id @default(uuid()) @db.Uuid
  dayOfWeek  Int        @map("day_of_week") // 0=Mon, 1=Tue, ... 6=Sun
  mealPeriod MealPeriod @map("meal_period")
  openTime   String     @map("open_time")  // "09:00"
  closeTime  String     @map("close_time") // "11:30"
  maxCovers  Int        @map("max_covers")
  isActive   Boolean    @default(true) @map("is_active")

  @@unique([dayOfWeek, mealPeriod])
  @@map("operating_hours")
}

model SpecialClosure {
  id        String   @id @default(uuid()) @db.Uuid
  date      DateTime @db.Date
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("special_closures")
}

model Booking {
  id                String            @id @default(uuid()) @db.Uuid
  reference         String            @unique // e.g. "TJ-A7X3"
  date              DateTime          @db.Date
  time              String            // "12:30"
  mealPeriod        MealPeriod        @map("meal_period")
  partySize         Int               @map("party_size")
  guestName         String            @map("guest_name")
  guestEmail        String            @map("guest_email")
  guestPhone        String            @map("guest_phone")
  specialRequests   String?           @map("special_requests")
  sectionPreference SectionPreference @default(NO_PREFERENCE) @map("section_preference")
  childrenCount     Int               @default(0) @map("children_count")
  status            BookingStatus     @default(CONFIRMED)
  cancelToken       String            @unique @default(uuid()) @map("cancel_token")
  adminNotes        String?           @map("admin_notes")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  notifications NotificationLog[]

  @@index([date])
  @@index([status])
  @@index([guestEmail])
  @@map("bookings")
}

model NotificationLog {
  id        String             @id @default(uuid()) @db.Uuid
  bookingId String             @map("booking_id") @db.Uuid
  type      NotificationType
  channel   String             @default("EMAIL")
  sentAt    DateTime           @default(now()) @map("sent_at")
  status    NotificationStatus

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("notification_log")
}

model MenuCategory {
  id        String     @id @default(uuid()) @db.Uuid
  name      String     // e.g. "Breakfast", "Starters", "Pizza"
  label     String     // short label e.g. "Morning", "To Start"
  sortOrder Int        @default(0) @map("sort_order")
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")

  items MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id          String       @id @default(uuid()) @db.Uuid
  categoryId  String       @map("category_id") @db.Uuid
  name        String
  description String?
  price       String       // e.g. "R121.00"
  sortOrder   Int          @default(0) @map("sort_order")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")

  category MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("menu_items")
}
